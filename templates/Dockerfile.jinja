{% if suffix %}FROM public.ecr.aws/docker/library/python:{{ python }}{{ suffix }}
{% else %}FROM public.ecr.aws/docker/library/python:{{ python }}
{% endif %}
LABEL maintainer="Damian Giebas"
LABEL license="MIT"

ENV POETRY_HOME=/opt/poetry
ENV PATH="$POETRY_HOME/bin/:${PATH}"
# Single atomic layer: a partial/interrupted pip install must never be cached
# and shipped. pip leaves tilde-prefixed backup dirs (e.g. ~platformdirs-*.dist-info)
# in site-packages when an upgrade is interrupted; those corrupt later
# `poetry self add`/importlib.metadata scans, so scrub them before the image is sealed.
RUN python3 -m venv "$POETRY_HOME" \
 && "$POETRY_HOME/bin/pip" install --no-cache-dir --upgrade pip \
 && "$POETRY_HOME/bin/pip" install --no-cache-dir "poetry=={{ poetry }}" \
 && find "$POETRY_HOME" -name '~*' -exec rm -rf {} + \
 && poetry --version
